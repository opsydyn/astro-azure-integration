{
  "name": "@opsydyn/astro-azure-swa",
  "version": "0.1.1",
  "description": "Native Astro 7 adapter for Azure Static Web Apps.",
  "author": "Alan Currie",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opsydyn/astro-azure-integration.git"
  },
  "bugs": {
    "url": "https://github.com/opsydyn/astro-azure-integration/issues"
  },
  "homepage": "https://github.com/opsydyn/astro-azure-integration#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/opsydyn"
  },
  "keywords": [
    "astro",
    "astro-adapter",
    "azure",
    "static-web-apps",
    "serverless"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.mts",
        "default": "./dist/server.mjs"
      }
    },
    "./bridge": {
      "import": {
        "types": "./dist/bridge.d.mts",
        "default": "./dist/bridge.mjs"
      }
    },
    "./preview": {
      "import": {
        "types": "./dist/preview.d.mts",
        "default": "./dist/preview.mjs"
      },
      "default": "./dist/preview.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prelint": "bun run build",
    "lint": "publint && attw --pack . --ignore-rules no-resolution --ignore-rules cjs-resolves-to-esm",
    "lint:knip": "knip",
    "docs:api": "typedoc",
    "docs:api:check": "typedoc --emit none",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "bun run build && changeset publish",
    "prepublishOnly": "bun run build",
    "pack:dry-run": "npm pack --dry-run",
    "size": "size-limit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "astro": "^7.0.0"
  },
  "dependencies": {
    "@azure/functions": "^4.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.31.0",
    "@size-limit/file": "^12.1.0",
    "astro": "^7.0.0",
    "knip": "^6.16.1",
    "publint": "^0.3.21",
    "size-limit": "^12.1.0",
    "tsdown": "^0.22.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "size-limit": [
    {
      "path": "dist/index.mjs",
      "limit": "15 KB"
    }
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
