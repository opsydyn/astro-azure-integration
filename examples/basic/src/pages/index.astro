---
import "../styles/global.css";
import ClientCounter from "../components/ClientCounter";
import EdenGreeter from "../components/EdenGreeter";
import FoldkitCounter from "../apps/foldkit-counter/app";
import PersonalizedServerIsland from "../components/PersonalizedServerIsland.astro";

const now = new Date().toISOString();
const checks = [
	["/server", "SSR route"],
	["/hybrid", "Hybrid prerendered route"],
	["/middleware", "Middleware header"],
	["/env", "Environment variables"],
	["/api/health", "JSON API"],
	["/api/echo", "POST echo API"],
	["/api/elysia", "Elysia router"],
	["/api/elysia/greet/swa", "Elysia param route"],
	["/api/elysia/openapi", "Elysia OpenAPI (Scalar UI)"],
	["/api/elysia/__openapi/dashboard", "Elysia Spectral lint dashboard"],
	["/form", "Form POST"],
	["/redirect", "Redirect + cookie"],
	["/cookies", "Multiple cookies"],
	["/auth", "Auth-like cookie flow"],
	["/blog", "Blog (content collections)"],
	["/blog/getting-started", "Blog post (prerendered MDX)"],
	["/not-found", "Astro 404"],
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Azure SWA Astro Adapter Demo</title>
  </head>
  <body>
    <main>
      <p class="eyebrow">Astro 6 on Azure Static Web Apps</p>
      <h1>Azure SWA Astro Adapter Demo</h1>
      <p data-testid="render-time">
        Rendered at {now}. This app exercises the routes used to validate the
        adapter locally and in Azure.
      </p>
      <section class="grid" aria-label="Adapter validation routes">
        {
          checks.map(([href, label]) => (
            <a class="card" href={href}>
              <span>{label}</span>
              <code>{href}</code>
            </a>
          ))
        }
      </section>
      <section class="showcase" aria-label="Astro island demos">
        <ClientCounter client:load />
        <FoldkitCounter client:load noMeta />
        <EdenGreeter client:load />
        <PersonalizedServerIsland server:defer>
          <section class="demo-panel" slot="fallback">
            <p class="eyebrow">Server island</p>
            <h2>Server island fallback</h2>
            <p>Loading delayed server-rendered content.</p>
          </section>
        </PersonalizedServerIsland>
      </section>
    </main>
  </body>
</html>
